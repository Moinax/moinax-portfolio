---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import type { Locale } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
}

const locale = (Astro.currentLocale ?? 'en') as Locale;
const { title, description = '' } = Astro.props;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Canonical link for this locale */}
    <link rel="canonical" href={getAbsoluteLocaleUrl(locale, '')} />

    {/* hreflang alternate links — absolute URLs required by Google */}
    {(['en', 'fr', 'nl'] as const).map((l) => (
      <link rel="alternate" hreflang={l} href={getAbsoluteLocaleUrl(l, '')} />
    ))}
    <link rel="alternate" hreflang="x-default" href={getAbsoluteLocaleUrl('en', '')} />

    {/* Self-hosted Inter font — preload weight 400 */}
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />

    <Analytics />
    <SpeedInsights />
  </head>
  <body class="selection:bg-cyan-500/30">
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/20 via-bg-deep to-bg-deep"></div>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <slot />
    </main>

    {/* Scroll-triggered animations — replaces framer-motion whileInView */}
    <script is:inline>
      (function() {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { rootMargin: '-50px', threshold: 0.1 });

        document.querySelectorAll('.animate-on-scroll').forEach(function(el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
