---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

// TODO v2: i18n title & meta description per locale (currently hardcoded EN)
const { title, description = "Jérôme Poskin - Frontend Lead & AI Architect. Multiplier human creativity with AI-powered engineering." } = Astro.props;
---

<!doctype html>
<!-- SSG limitation: lang="fr" is static at build time. The LanguageContext updates it client-side after hydration.
     Crawlers/screen readers will initially see lang="fr". Acceptable for a portfolio site. -->
<html lang="fr" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap" rel="stylesheet">
		<!-- FOUC mitigation: apply saved locale before first paint to avoid flash of FR content -->
		<script is:inline>
			(function() {
				var stored = localStorage.getItem('preferred-locale');
				if (stored && ['fr', 'en', 'nl'].indexOf(stored) !== -1) {
					document.documentElement.lang = stored;
				}
			})();
		</script>
	</head>
	<body class="selection:bg-cyan-500/30">
		<div class="fixed inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/20 via-bg-deep to-bg-deep"></div>
		
		<main class="max-w-5xl mx-auto px-6 py-12">
			<slot />
		</main>
	</body>
</html>
