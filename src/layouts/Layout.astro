---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import type { Locale } from '../i18n/index';
import { locales } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
}

const { title, description, locale } = Astro.props;
const siteUrl = 'https://www.moinax.com';
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <!-- hreflang alternate links -->
    {locales.map((l) => (
      <link rel="alternate" hreflang={l} href={`${siteUrl}/${l}/`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />
    <link rel="canonical" href={`${siteUrl}/${locale}/`} />

    <!-- Self-hosted Inter font -->
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <Analytics />
    <SpeedInsights />
  </head>
  <body class="selection:bg-cyan-500/30">
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/20 via-bg-deep to-bg-deep"></div>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <slot />
    </main>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '-50px', threshold: 0.01 }
      );
      document.querySelectorAll('.scroll-fade-up, .scroll-fade-left').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
