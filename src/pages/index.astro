---
// Fallback redirect for non-Vercel environments.
// On Vercel, vercel.json handles the Accept-Language redirect.
// This page serves as a static fallback with meta refresh + JS.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0;url=/en/" />
    <title>Redirecting…</title>
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('preferred-locale');
        var locales = ['en', 'fr', 'nl'];
        if (stored && locales.indexOf(stored) !== -1) {
          window.location.replace('/' + stored + '/');
          return;
        }
        var lang = (navigator.language || '').split('-')[0].toLowerCase();
        if (locales.indexOf(lang) !== -1) {
          window.location.replace('/' + lang + '/');
        } else {
          window.location.replace('/en/');
        }
      })();
    </script>
  </head>
  <body></body>
</html>
