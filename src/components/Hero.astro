---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/t';
import { yearsOfExperience } from '../lib/constants';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="min-h-[85vh] flex flex-col justify-center items-start space-y-8 py-20 relative">
  <!-- Ambient glow -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-indigo-600/10 rounded-full blur-[128px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-cyan-600/10 rounded-full blur-[128px] pointer-events-none"></div>

  <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm font-medium fade-up" style="--delay: 0ms;">
    <!-- Bot icon (lucide) -->
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8V4H8"/><rect x="4" y="8" width="16" height="12" rx="2"/><circle cx="9" cy="13" r="1"/><circle cx="15" cy="13" r="1"/></svg>
    <span>{t(locale, 'hero.badge')}</span>
  </div>

  <div class="space-y-6 max-w-4xl">
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-[1.05] fade-up" style="--delay: 100ms;">
      Jérôme Poskin
    </h1>

    <p class="text-2xl sm:text-3xl md:text-4xl font-bold text-gradient leading-tight fade-up" style="--delay: 150ms;">
      {t(locale, 'hero.tagline')}
    </p>

    <p class="text-lg md:text-xl text-slate-400 leading-relaxed max-w-2xl fade-up" style="--delay: 250ms;">
      {t(locale, 'hero.description', { years: yearsOfExperience })}
    </p>
  </div>

  <div class="flex flex-wrap gap-6 pt-4 fade-up" style="--delay: 350ms;">
    <div class="flex items-center gap-2 text-slate-300">
      <!-- Code2 icon -->
      <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m18 16 4-4-4-4"/><path stroke-linecap="round" stroke-linejoin="round" d="m6 8-4 4 4 4"/><path stroke-linecap="round" stroke-linejoin="round" d="m14.5 4-5 16"/></svg>
      <span class="font-medium">{t(locale, 'hero.react_expert')}</span>
    </div>
    <div class="w-px h-6 bg-slate-700"></div>
    <div class="flex items-center gap-2 text-slate-300">
      <!-- Sparkles icon -->
      <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4"/><path stroke-linecap="round" stroke-linejoin="round" d="M19 17v4"/><path stroke-linecap="round" stroke-linejoin="round" d="M3 5h4"/><path stroke-linecap="round" stroke-linejoin="round" d="M17 19h4"/></svg>
      <span class="font-medium">{t(locale, 'hero.ai_workflow')}</span>
    </div>
    <div class="w-px h-6 bg-slate-700"></div>
    <div class="flex items-center gap-2 text-slate-300">
      <span class="font-medium text-slate-400">{t(locale, 'hero.xp_years', { years: yearsOfExperience })}</span>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 fade-in" style="--delay: 1000ms;">
    <a href="#about" class="text-slate-600 hover:text-cyan-400 transition-colors">
      <!-- ArrowDown icon -->
      <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14"/><path stroke-linecap="round" stroke-linejoin="round" d="m19 12-7 7-7-7"/></svg>
    </a>
  </div>
</section>
