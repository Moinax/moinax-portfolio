---
import type { Locale } from '../i18n/index';
import { t } from '../i18n/t';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const skillGroups = [
  { categoryKey: 'skills.frontend', items: ['React.js', 'Next.js', 'TypeScript', 'Astro', 'Electron'] },
  { categoryKey: 'skills.styling', items: ['Tailwind CSS', 'Sass/SCSS', 'Design Systems', 'Responsive Design', 'Accessibility'] },
  { categoryKey: 'skills.data', items: ['GraphQL', 'Relay', 'Redux', 'REST APIs', 'Node.js'] },
  { categoryKey: 'skills.ai', items: ['LLM Integration', 'AI Agents', 'Prompt Engineering', 'Copilot Workflows', 'Automated Code Review'] },
  { categoryKey: 'skills.tools', items: ['Git', 'Webpack', 'Vite', 'Agile/Scrum', 'CI/CD'] },
];
---

<section id="skills" class="py-24 space-y-12">
  <h2 class="text-4xl font-bold scroll-fade-up">
    {t(locale, 'skills.title')}<span class="text-gradient">.</span>
  </h2>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {skillGroups.map((group, i) => (
      <div class="glass-card p-6 space-y-4 hover:border-white/20 transition-colors scroll-fade-up" style={`--delay: ${i * 100}ms;`}>
        <h3 class="text-sm font-bold uppercase tracking-wider text-cyan-400">
          {t(locale, group.categoryKey)}
        </h3>
        <div class="flex flex-wrap gap-2">
          {group.items.map((item) => (
            <span class="text-sm px-3 py-1 rounded-lg bg-white/5 text-slate-300 border border-white/5 hover:border-cyan-500/30 hover:text-cyan-300 transition-colors cursor-default">
              {item}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
