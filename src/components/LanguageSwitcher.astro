---
import { locales, localeLabels, localeNames, type Locale } from '../i18n/index';

interface Props {
  locale: Locale;
  size?: 'desktop' | 'mobile';
}

const { locale, size = 'desktop' } = Astro.props;
---

<div role="group" aria-label="Language selector" class:list={['flex items-center gap-1', { 'gap-3': size === 'mobile' }]}>
  {locales.map((l, i) => (
    <span class="flex items-center">
      <a
        href={`/${l}/`}
        aria-label={localeNames[l]}
        aria-current={locale === l ? 'page' : undefined}
        class:list={[
          'font-medium tracking-wide px-2 py-1 rounded-md transition-all duration-200',
          'focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-400/50',
          size === 'mobile' ? 'text-sm min-h-[44px] min-w-[44px] flex items-center justify-center' : 'text-xs',
          locale === l
            ? 'text-cyan-400 bg-cyan-400/10 font-semibold'
            : 'text-slate-500 hover:text-slate-200 hover:bg-white/5',
        ]}
        data-locale={l}
      >
        {localeLabels[l]}
      </a>
      {i < locales.length - 1 && (
        <span class:list={['text-slate-600 select-none', size === 'mobile' ? 'text-sm' : 'text-xs']} aria-hidden="true">·</span>
      )}
    </span>
  ))}
</div>

<script>
  // Set preferred-locale cookie on language switch
  document.querySelectorAll('[data-locale]').forEach((el) => {
    el.addEventListener('click', () => {
      const locale = (el as HTMLElement).dataset.locale;
      if (locale) {
        document.cookie = `preferred-locale=${locale};path=/;max-age=${60 * 60 * 24 * 365};SameSite=Lax`;
        localStorage.setItem('preferred-locale', locale);
      }
    });
  });
</script>
