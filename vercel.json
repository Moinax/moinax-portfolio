    },
    {
      "source": "/",
      "has": [{ "type": "header", "key": "accept-language", "value": "^nl" }],
      "destination": "/nl/",
      "statusCode": 302
    },
    {
      "source": "/",
      "destination": "/en/",
      "statusCode": 302
    }
  ]
}
